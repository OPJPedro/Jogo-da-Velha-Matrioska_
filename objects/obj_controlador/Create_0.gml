
//tabuleiro cria uma lista de 3 valores. Na qual todos são preenchidos com 0
tabuleiro = array_create(3);

//cria um número constante que vai até 3 [i].
for (var i = 0; i < 3; i++)
{
	//tabuleiro cria 3 listas preenchidas com 0. Uma grid.
    tabuleiro[i] = array_create(3, 0);
};

/* cria:

	0 0 0
	0 0 0
	0 0 0
	
*/